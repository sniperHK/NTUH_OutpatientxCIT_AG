{
  "name": "cit-clinic-violence-workshop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:slides:m01": "slidev build slides/S-M01.md --base /slides/S-M01/ --out ../public/slides/S-M01",
    "build:slides:m03": "slidev build slides/S-M03.md --base /slides/S-M03/ --out ../public/slides/S-M03",
    "build:slides:m04": "slidev build slides/S-M04.md --base /slides/S-M04/ --out ../public/slides/S-M04",
    "build:slides:m05": "slidev build slides/S-M05.md --base /slides/S-M05/ --out ../public/slides/S-M05",
    "build:slides": "npm run build:slides:m01 && npm run build:slides:m03 && npm run build:slides:m04 && npm run build:slides:m05",
    "build:all": "npm run build:slides && npm run build",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "react-router-dom": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@slidev/cli": "^52.14.2",
    "@slidev/theme-default": "^0.25.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.0"
  }
}
