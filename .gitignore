# macOS
.DS_Store

# Plaintext env files should never be committed
.env
.env.missing
.env.local
.env.*.local

# age private key should never be committed
age-key.txt

# Encrypted env files are safe to commit
!.env.age
!.env.*.age

# Node
web/node_modules/
web/dist/

# Superpowers brainstorming
.superpowers/

# Slidev build output (generated, not tracked)
web/public/slides/

# TypeScript build info
web/tsconfig.tsbuildinfo
server/node_modules/
